---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Inicio — H&H Diseño Fabricacion y Montaje"
  description="Líderes en Diseño, Fabricación Estructural y Montaje Industrial. Cotiza tu proyecto con los expertos en metalmecánica."
>
  <!-- 1. Hero -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container hero-content text-center">
      <img src="/logo_2.png" alt="H&H Diseño Fabricación y Montaje" class="hero-logo animate-fade-up" />
      <span class="hero-badge animate-fade-up" style="animation-delay: 0.1s">SEGURIDAD, EFICIENCIA y CALIDAD</span>
      <h1 class="animate-fade-up" style="animation-delay: 0.2s">DISEÑO Y FABRICACIÓN <br/> <span class="text-accent">METALMECÁNICA</span></h1>
      <p class="hero-subtitle animate-fade-up" style="animation-delay: 0.3s">Transformamos el acero en soluciones estructurales de máxima precisión para el sector industrial. Garantizamos ingeniería robusta y montajes seguros.</p>
      <div class="hero-actions animate-fade-up" style="animation-delay: 0.4s">
        <a href="#contacto" class="btn btn-primary">Cotizar Proyecto</a>
        <a href="/servicios" class="btn btn-secondary">Nuestros Servicios</a>
      </div>
    </div>
    <div class="scroll-indicator">
      <div class="scroll-dot"></div>
    </div>
  </section>

  <!-- 2. Stats Bar -->
  <section class="stats-bar" id="stats">
    <div class="container">
      <div class="grid-4 stats-grid">
        <div class="stat-item">
          <span class="stat-prefix">+</span><span class="stat-number" data-target="5">0</span>
          <span class="stat-label">Años de Experiencia</span>
        </div>
        <div class="stat-item">
          <span class="stat-prefix">+</span><span class="stat-number" data-target="350">0</span>
          <span class="stat-label">Proyectos Entregados</span>
        </div>
        <div class="stat-item">
          <span class="stat-prefix">+</span><span class="stat-number" data-target="10000">0</span>
          <span class="stat-label">Toneladas en Fabricación de Acero</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="100">0</span><span>%</span>
          <span class="stat-label">Calidad Garantizada</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Services/Offerings Grid -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Nuestras Especialidades</span>
        <h2>Nuestros Servicios</h2>
      </div>
      <div class="grid-3">
        <a href="/servicios#ingenieria" class="service-card">
          <div class="service-icon-wrapper">
             <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
          </div>
          <h3>Ingeniería y Proyectos</h3>
          <p>Diseño de estructuras metálicas, piezas mecánicas, memoria de cálculo y dossier de calidad.</p>
          <span class="service-link">Saber Más →</span>
        </a>
        <a href="/servicios#fabricacion" class="service-card">
          <div class="service-icon-wrapper">
             <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
          </div>
          <h3>Fabricación y Montaje</h3>
          <p>Fabricación de estructuras livianas y pesadas con procesos SMAW, FCAW, GMAW y GTAW.</p>
          <span class="service-link">Saber Más →</span>
        </a>
        <a href="/servicios#mantenimiento" class="service-card">
          <div class="service-icon-wrapper">
            <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"></path></svg>
          </div>
          <h3>Mantenimiento Industrial</h3>
          <p>Mantenimiento preventivo, predictivo y correctivo para instalaciones industriales y mineras.</p>
          <span class="service-link">Saber Más →</span>
        </a>
        <a href="/servicios#piezas" class="service-card">
          <div class="service-icon-wrapper">
             <svg viewBox="0 0 24 24"><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          </div>
          <h3>Piezas Mecánicas</h3>
          <p>Fabricación y reconstrucción a medida en torno y fresadora con tolerancias precisas.</p>
          <span class="service-link">Saber Más →</span>
        </a>
        <a href="/servicios#acabado" class="service-card">
          <div class="service-icon-wrapper">
             <svg viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"></path></svg>
          </div>
          <h3>Acabado Superficial</h3>
          <p>Tratamientos anticorrosivos, arenado industrial y pintura electrostática, epóxica y poliuretano.</p>
          <span class="service-link">Saber Más →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. Contact Form -->
  <section class="section" id="contacto">
    <div class="container">
      <div class="grid-2 contact-grid">
        <div class="contact-info">
          <span class="section-tag">¿Hablamos?</span>
          <h2>Inicia tu Proyecto con Nosotros</h2>
          <p>Déjanos tus datos y un especialista en ingeniería técnica se pondrá en contacto contigo en las próximas 24 horas para cotizar tu proyecto.</p>
          <ul class="contact-list">
            <li>
              <div class="icon-box"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg></div>
              <div>
                <strong>Nuestra Oficina</strong>
                <p>Calle Huánuco G19 Mz F2 Lt 4 – Semi Rural Pachacútec, Cerro Colorado – Arequipa</p>
              </div>
            </li>
            <li>
              <div class="icon-box"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg></div>
              <div>
                <strong>Llámanos Directamente</strong>
                <p>+51 921 941 470</p>
              </div>
            </li>
            <li>
              <div class="icon-box"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg></div>
              <div>
                <strong>Correo Electrónico</strong>
                <p>servicios@hhdfm.com / hyh.dfm@gmail.com</p>
              </div>
            </li>
          </ul>

          <!-- Mapa y Navegación en el panel izquierdo -->
          <div class="map-left-panel" style="margin-top: var(--space-xl);">
            <div style="border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); height: 250px;">
              <iframe 
                src="https://maps.google.com/maps?q=Calle%20Hu%C3%A1nuco%2C%20Cerro%20Colorado%2C%20Arequipa%2C%20Per%C3%BA&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                width="100%" 
                height="100%" 
                style="border:0;"
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); margin-top: var(--space-md);">
              <!-- Enlaces de navegación -->
              <div class="nav-links" style="display: flex; flex-direction: column; align-items: center; background: var(--color-surface); padding: var(--space-md); border-radius: var(--radius-sm); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm);">
                <span style="font-size: 0.9rem; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 12px; text-align: center;">¿Cómo llegar?</span>
                <div style="display: flex; gap: 20px; justify-content: center;">
                  <a href="https://www.google.com/maps/dir/?api=1&destination=Calle+Huánuco+G19+Mz+F2+Lt+4+Semi+Rural+Pachacútec,+Cerro+Colorado,+Arequipa" target="_blank" rel="noopener noreferrer" class="app-link-icon" title="Google Maps">
                    <img src="https://api.iconify.design/logos:google-maps.svg" alt="Google Maps" width="36" height="36" />
                  </a>
                  <a href="https://waze.com/ul?q=Calle+Hu%C3%A1nuco+G19+Mz+F2+Lt+4+Semi+Rural+Pachac%C3%BAtec,+Cerro+Colorado,+Arequipa&navigate=yes" target="_blank" rel="noopener noreferrer" class="app-link-icon" title="Waze">
                    <img src="https://api.iconify.design/simple-icons:waze.svg?color=%2333ccff" alt="Waze" width="36" height="36" />
                  </a>
                  <a href="http://maps.apple.com/?daddr=Calle+Hu%C3%A1nuco+G19+Mz+F2+Lt+4+Semi+Rural+Pachac%C3%BAtec,+Cerro+Colorado,+Arequipa" target="_blank" rel="noopener noreferrer" class="app-link-icon" title="Apple Maps">
                    <img src="https://api.iconify.design/logos:apple.svg" alt="Apple Maps" width="36" height="36" />
                  </a>
                </div>
              </div>

              <!-- Redes sociales -->
              <div class="social-links" style="display: flex; flex-direction: column; align-items: center; background: var(--color-surface); padding: var(--space-md); border-radius: var(--radius-sm); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm);">
                <span style="font-size: 0.9rem; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 12px; text-align: center;">Síguenos:</span>
                <div style="display: flex; gap: 20px; justify-content: center;">
                  <a href="https://www.facebook.com/search/top?q=H%26H%20Dise%C3%B1o%20Fabricaci%C3%B3n%20y%20Montaje" target="_blank" rel="noopener noreferrer" class="app-link-icon" title="Facebook">
                    <img src="https://api.iconify.design/logos:facebook.svg" alt="Facebook" width="36" height="36" />
                  </a>
                  <a href="https://www.linkedin.com/search/results/all/?keywords=H%26H%20Dise%C3%B1o%20Fabricaci%C3%B3n%20y%20Montaje" target="_blank" rel="noopener noreferrer" class="app-link-icon" title="LinkedIn">
                    <img src="https://api.iconify.design/logos:linkedin-icon.svg" alt="LinkedIn" width="36" height="36" />
                  </a>
                  <a href="https://wa.me/51921941470" target="_blank" rel="noopener noreferrer" class="app-link-icon" title="WhatsApp">
                    <img src="https://api.iconify.design/logos:whatsapp-icon.svg" alt="WhatsApp" width="36" height="36" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="form-wrapper">
          <form id="contact-form" class="styled-form">
            <div class="grid-2" style="gap: var(--space-md); grid-template-columns: 1fr 1fr; margin-bottom: 0;">
              <div class="form-group">
                <label for="name" class="form-label">Nombre o Empresa *</label>
                <input type="text" id="name" name="name" class="form-control" required />
              </div>
              <div class="form-group">
                <label for="phone" class="form-label">Teléfono *</label>
                <input type="tel" id="phone" name="phone" class="form-control" required />
              </div>
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Correo Electrónico *</label>
              <input type="email" id="email" name="email" class="form-control" required />
            </div>
            <div class="form-group">
              <label for="service" class="form-label">Servicio de Interés</label>
              <select id="service" name="service" class="form-control">
                <option value="">Selecciona una opción...</option>
                <option value="ingenieria">Ingeniería y Proyectos</option>
                <option value="fabricacion">Fabricación y Montaje de Estructuras</option>
                <option value="mantenimiento">Mantenimiento Industrial</option>
                <option value="piezas">Fabricación de Piezas Mecánicas</option>
                <option value="acabado">Preparación y Acabado Superficial</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message" class="form-label">Detalles del Proyecto</label>
              <textarea id="message" name="message" class="form-control" placeholder="Cuéntanos brevemente qué necesitas..." required></textarea>
            </div>
            <button type="submit" id="contact-submit" class="btn btn-primary" style="width: 100%;">Enviar Mensaje</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-image: url('https://images.unsplash.com/photo-1501523460185-2aa5d2a0f981?w=1600&h=900&fit=crop');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26,76,132,0.85), rgba(49,115,186,0.92));
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: var(--header-height);
  }
  .hero-logo {
    max-width: 180px; /* Mobile Default */
    height: auto;
    margin: 0 auto var(--space-xl) auto;
    filter: drop-shadow(0 8px 30px rgba(0,0,0,0.3));
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: white;
    padding: 6px 16px;
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    border: 1px solid rgba(255,255,255,0.3);
  }
  .hero-section h1 {
    color: white;
    margin-bottom: var(--space-md);
  }
  .text-accent { color: var(--color-accent-light); }
  .hero-subtitle {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem; /* Mobile Default */
    max-width: 700px;
    margin: 0 auto var(--space-xl) auto;
  }
  .hero-actions { display: flex; gap: var(--space-md); justify-content: center; flex-direction: column; width: 100%; } /* Default mobile stacked */
  
  .scroll-indicator {
    position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
    width: 30px; height: 50px; border: 2px solid rgba(255,255,255,0.5);
    border-radius: 20px; z-index: 2;
  }
  .scroll-dot {
    width: 6px; height: 10px; background: white; border-radius: 3px;
    margin: 8px auto 0;
    animation: scrollBounce 2s infinite cubic-bezier(0.15, 0.41, 0.69, 0.94);
  }
  @keyframes scrollBounce {
    0% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(20px); opacity: 0; }
    100% { transform: translateY(0); opacity: 0; }
  }

  /* Stats Bar */
  .stats-bar { background: var(--grad-primary); padding: var(--space-xl) 0; }
  .stats-grid { display: grid; gap: var(--space-xl); grid-template-columns: repeat(2, 1fr); text-align: center; } /* Mobile default */
  .stat-number, .stat-percent, .stat-prefix { font-family: var(--font-heading); font-size: 2.5rem; color: var(--color-accent); font-weight: 700; line-height: 1; display: inline-block; }
  .stat-prefix { margin-right: 2px; }
  .stat-label { display: block; color: rgba(255,255,255,0.7); font-size: 0.85rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; margin-top: var(--space-xs); }

  /* Services Grid */
  .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-lg); }
  .service-card { display: block; background: var(--color-surface); padding: var(--space-xl); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--color-border); transition: all var(--transition-base); }
  .service-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); border-color: var(--color-accent); }
  .service-icon-wrapper { width: 72px; height: 72px; background: linear-gradient(135deg, rgba(49,115,186,0.1), rgba(49,115,186,0.05)); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; margin-bottom: var(--space-lg); transition: all var(--transition-base); }
  .service-card:hover .service-icon-wrapper { background: var(--color-accent); }
  .service-icon-wrapper svg { width: 36px; height: 36px; fill: none; stroke: var(--color-primary); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; transition: all var(--transition-base); }
  .service-card:hover .service-icon-wrapper svg { stroke: white; }
  .service-card h3 { color: var(--color-primary); margin-bottom: var(--space-sm); }
  .service-card p { color: var(--color-text-secondary); margin-bottom: var(--space-lg); }
  .service-link { font-weight: 600; color: var(--color-primary); text-transform: uppercase; font-size: 0.9rem; letter-spacing: 0.05em; transition: all var(--transition-base); }
  .service-card:hover .service-link { color: var(--color-accent); margin-left: 5px; }

  /* Contact Form */
  .grid-2 { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: center; } /* Mobile default */
  .contact-grid { align-items: start; }
  .contact-list { margin-top: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-lg); }
  .contact-list li { display: flex; gap: var(--space-md); align-items: flex-start; }
  .icon-box { width: 48px; height: 48px; background: rgba(49,115,186,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .icon-box svg { width: 24px; height: 24px; stroke: var(--color-primary); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .contact-list strong { display: block; font-size: 1.1rem; color: var(--color-primary); margin-bottom: 4px; }
  .contact-list p { margin: 0; color: var(--color-text-secondary); }
  .form-wrapper { background: var(--color-surface); padding: var(--space-lg); border-radius: var(--radius-md); box-shadow: var(--shadow-md); border: 1px solid var(--color-border); }

  .mt-xl { margin-top: var(--space-xl); }

  /* Tablet */
  @media (min-width: 481px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); gap: var(--space-lg); }
    .stat-number, .stat-percent, .stat-prefix { font-size: 3rem; }
    .stat-label { font-size: 0.95rem; }
    .hero-actions { flex-direction: row; width: auto; }
    .hero-subtitle { font-size: 1.15rem; }
    .hero-logo { max-width: 250px; }
    .form-wrapper { padding: var(--space-xl); }
  }

  /* Desktop */
  @media (min-width: 1025px) {
    .grid-2 { grid-template-columns: 1fr 1.2fr; gap: var(--space-4xl); }
    .stat-number, .stat-percent, .stat-prefix { font-size: 3.5rem; }
    .stat-label { font-size: 1rem; }
    .hero-subtitle { font-size: 1.25rem; }
    .hero-logo { max-width: 340px; }
    .form-wrapper { padding: var(--space-2xl); }
  }

  .app-link-icon {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .app-link-icon:hover {
    transform: scale(1.1);
    opacity: 0.9;
  }
</style>

<script>
  // Counter Animation
  function animateCounters() {
    document.querySelectorAll('.stat-number').forEach(counter => {
      const target = parseInt(counter.getAttribute('data-target') || '0', 10);
      const duration = 2000;
      const stepTime = 20;
      const steps = duration / stepTime;
      const increment = target / steps;
      let current = 0;
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          counter.textContent = target.toString();
          clearInterval(timer);
        } else {
          counter.textContent = Math.floor(current).toString();
        }
      }, stepTime);
    });
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounters();
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });
  
  const statsSection = document.getElementById('stats');
  if (statsSection) observer.observe(statsSection);

  // Form Submission feedback
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('contact-submit');
    if(btn) {
      const originalText = btn.textContent;
      btn.textContent = '¡Mensaje enviado! ✓';
      btn.style.background = 'var(--color-success)';
      btn.style.borderColor = 'var(--color-success)';
      setTimeout(() => {
        btn.textContent = originalText;
        btn.style.background = '';
        btn.style.borderColor = '';
        form.reset();
      }, 3000);
    }
  });
</script>
