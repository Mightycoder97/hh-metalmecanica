---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Inicio — H&H Diseño Fabricacion y Montaje"
  description="Líderes en Diseño, Fabricación Estructural y Montaje Industrial. Cotiza tu proyecto con los expertos en metalmecánica."
>
  <!-- 1. Hero -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container hero-content text-center">
      <span class="hero-badge animate-fade-up">Experiencia y Calidad</span>
      <h1 class="animate-fade-up" style="animation-delay: 0.1s">DISEÑO Y FABRICACIÓN <br/> <span class="text-accent">METALMECÁNICA</span></h1>
      <p class="hero-subtitle animate-fade-up" style="animation-delay: 0.2s">Transformamos el acero en soluciones estructurales de máxima precisión para el sector industrial. Garantizamos ingeniería robusta y montajes seguros.</p>
      <div class="hero-actions animate-fade-up" style="animation-delay: 0.3s">
        <a href="#contacto" class="btn btn-primary">Cotizar Proyecto</a>
        <a href="/servicios" class="btn btn-secondary">Nuestros Servicios</a>
      </div>
    </div>
    <div class="scroll-indicator">
      <div class="scroll-dot"></div>
    </div>
  </section>

  <!-- 2. Stats Bar -->
  <section class="stats-bar" id="stats">
    <div class="container">
      <div class="grid-4 stats-grid">
        <div class="stat-item">
          <span class="stat-number" data-target="15">0</span>
          <span class="stat-label">Años de Experiencia</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="350">0</span>
          <span class="stat-label">Proyectos Entregados</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="5000">0</span>
          <span class="stat-label">Toneladas de Acero</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="100">0</span><span>%</span>
          <span class="stat-label">Calidad Garantizada</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. About Preview -->
  <section class="section">
    <div class="container">
      <div class="grid-2 about-preview">
        <div class="about-image-wrapper">
          <img src="https://images.unsplash.com/photo-1581092162384-8987c1d64718?w=800&h=900&fit=crop" alt="Trabajador metalmecánico de H&H" class="about-img" loading="lazy" />
          <div class="about-badge">
            <span class="badge-number">#1</span>
            <span class="badge-text">En Calidad Estructural</span>
          </div>
        </div>
        <div class="about-content">
          <span class="section-tag">Sobre Nosotros</span>
          <h2>Ingeniería Robusta, Ejecución Precisa</h2>
          <p>En H&H Diseño Fabricación y Montaje, nos especializamos en brindar soluciones integrales en metalmecánica para la industria pesada y construcción civil.</p>
          <ul class="feature-list">
            <li>
              <span class="feature-icon">✓</span>
              <div>
                <strong>Alta Tecnología</strong>
                <p>Equipos de corte y soldadura de última generación.</p>
              </div>
            </li>
            <li>
              <span class="feature-icon">✓</span>
              <div>
                <strong>Personal Homologado</strong>
                <p>Ingenieros, soldadores y técnicos altamente capacitados.</p>
              </div>
            </li>
          </ul>
          <a href="/nosotros" class="btn btn-outline" style="margin-top: 1rem;">Conoce Más</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Main Offering Preview -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Capacidad Operativa</span>
        <h2>Instalaciones de Primer Nivel</h2>
        <p>Contamos con una extensa planta de fabricación equipada para procesar proyectos de gran envergadura.</p>
      </div>
      <div class="offering-grid">
        <div class="offering-card large">
          <img src="https://images.unsplash.com/photo-1455165814004-1126a7199f9b?w=800&h=800&fit=crop" alt="Taller de fabricación H&H" class="offering-img" loading="lazy" />
          <div class="offering-overlay">
            <h3>Planta Central</h3>
          </div>
        </div>
        <div class="offering-card">
          <img src="https://images.unsplash.com/photo-1496247749665-49cf5b1022e9?w=600&h=400&fit=crop" alt="Estructuras de acero" class="offering-img" loading="lazy" />
          <div class="offering-overlay">
            <h3>Almacén de Acero</h3>
          </div>
        </div>
        <div class="offering-card">
          <img src="https://images.unsplash.com/photo-1581092335397-9583eb92d232?w=600&h=400&fit=crop" alt="Soldadura industrial" class="offering-img" loading="lazy" />
          <div class="offering-overlay">
            <h3>Centro de Soldadura</h3>
          </div>
        </div>
      </div>
      <div class="text-center mt-xl">
        <a href="/proyectos" class="btn btn-primary">Ver Portafolio de Proyectos</a>
      </div>
    </div>
  </section>

  <!-- 5. Services/Offerings Grid -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Nuestras Especialidades</span>
        <h2>Nuestros Servicios</h2>
      </div>
      <div class="grid-3">
        <a href="/servicios#diseno" class="service-card">
          <div class="service-icon-wrapper">
             <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
          </div>
          <h3>Diseño de Ingeniería</h3>
          <p>Desarrollo de planos estructurales, cálculo de cargas y diseño de piezas mecánicas a medida.</p>
          <span class="service-link">Saber Más →</span>
        </a>
        <a href="/servicios#fabricacion" class="service-card">
          <div class="service-icon-wrapper">
             <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
          </div>
          <h3>Fabricación Estructural</h3>
          <p>Corte, rolado, plegado y soldadura para estructuras de acero pesado y liviano con precisión milimétrica.</p>
          <span class="service-link">Saber Más →</span>
        </a>
        <a href="/servicios#montaje" class="service-card">
          <div class="service-icon-wrapper">
            <svg viewBox="0 0 24 24"><path d="M3 21h18v-2H3v2zm9-4V3m-5 9l5-5 5 5"></path></svg>
          </div>
          <h3>Montaje Industrial</h3>
          <p>Instalación en campo de techos parabólicos, naves industriales, tanques y tuberías bajo estrictas normas de seguridad.</p>
          <span class="service-link">Saber Más →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 7. Contact Form -->
  <section class="section" id="contacto">
    <div class="container">
      <div class="grid-2 contact-grid">
        <div class="contact-info">
          <span class="section-tag">¿Hablamos?</span>
          <h2>Inicia tu Proyecto con Nosotros</h2>
          <p>Déjanos tus datos y un especialista en ingeniería técnica se pondrá en contacto contigo en las próximas 24 horas para cotizar tu proyecto.</p>
          <ul class="contact-list">
            <li>
              <div class="icon-box"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg></div>
              <div>
                <strong>Nuestra Oficina Central</strong>
                <p>Lima, Perú</p>
              </div>
            </li>
            <li>
              <div class="icon-box"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg></div>
              <div>
                <strong>Llámanos Directamente</strong>
                <p>+51 999 999 999</p>
              </div>
            </li>
          </ul>
        </div>
        
        <div class="form-wrapper">
          <form id="contact-form" class="styled-form">
            <div class="grid-2" style="gap: var(--space-md); grid-template-columns: 1fr 1fr; margin-bottom: 0;">
              <div class="form-group">
                <label for="name" class="form-label">Nombre o Empresa *</label>
                <input type="text" id="name" name="name" class="form-control" required />
              </div>
              <div class="form-group">
                <label for="phone" class="form-label">Teléfono *</label>
                <input type="tel" id="phone" name="phone" class="form-control" required />
              </div>
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Correo Electrónico *</label>
              <input type="email" id="email" name="email" class="form-control" required />
            </div>
            <div class="form-group">
              <label for="service" class="form-label">Servicio de Interés</label>
              <select id="service" name="service" class="form-control">
                <option value="">Selecciona una opción...</option>
                <option value="fabricacion">Fabricación Estructural</option>
                <option value="montaje">Montaje Industrial</option>
                <option value="diseno">Diseño de Ingeniería</option>
                <option value="mantenimiento">Mantenimiento/Inspección</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message" class="form-label">Detalles del Proyecto</label>
              <textarea id="message" name="message" class="form-control" placeholder="Cuéntanos brevemente qué necesitas..." required></textarea>
            </div>
            <button type="submit" id="contact-submit" class="btn btn-primary" style="width: 100%;">Enviar Mensaje</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-image: url('https://images.unsplash.com/photo-1501523460185-2aa5d2a0f981?w=1600&h=900&fit=crop');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26,76,132,0.85), rgba(49,115,186,0.92));
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: var(--header-height);
  }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: white;
    padding: 6px 16px;
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    border: 1px solid rgba(255,255,255,0.3);
  }
  .hero-section h1 {
    color: white;
    margin-bottom: var(--space-md);
  }
  .text-accent { color: var(--color-accent-light); }
  .hero-subtitle {
    color: rgba(255,255,255,0.8);
    font-size: 1.25rem;
    max-width: 700px;
    margin: 0 auto var(--space-xl) auto;
  }
  .hero-actions { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
  
  .scroll-indicator {
    position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
    width: 30px; height: 50px; border: 2px solid rgba(255,255,255,0.5);
    border-radius: 20px; z-index: 2;
  }
  .scroll-dot {
    width: 6px; height: 10px; background: white; border-radius: 3px;
    margin: 8px auto 0;
    animation: scrollBounce 2s infinite cubic-bezier(0.15, 0.41, 0.69, 0.94);
  }
  @keyframes scrollBounce {
    0% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(20px); opacity: 0; }
    100% { transform: translateY(0); opacity: 0; }
  }

  /* Stats Bar */
  .stats-bar { background: var(--grad-primary); padding: var(--space-xl) 0; }
  .stats-grid { display: grid; gap: var(--space-lg); grid-template-columns: repeat(4, 1fr); text-align: center; }
  .stat-number, .stat-percent { font-family: var(--font-heading); font-size: 3.5rem; color: var(--color-accent); font-weight: 700; line-height: 1; display: inline-block; }
  .stat-label { display: block; color: rgba(255,255,255,0.7); font-size: 1rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; margin-top: var(--space-xs); }

  /* About Preview */
  .grid-2 { display: grid; grid-template-columns: 1fr 1.2fr; gap: var(--space-4xl); align-items: center; }
  .about-image-wrapper { position: relative; }
  .about-img { width: 100%; border-radius: var(--radius-md); box-shadow: var(--shadow-lg); }
  .about-badge { position: absolute; bottom: -20px; right: -20px; background: var(--color-surface); padding: var(--space-lg); border-radius: var(--radius-md); box-shadow: var(--shadow-xl); display: flex; flex-direction: column; align-items: center; border-left: 4px solid var(--color-accent); }
  .badge-number { font-family: var(--font-heading); font-size: 3rem; font-weight: 700; color: var(--color-primary); line-height: 1; }
  .badge-text { font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-secondary); text-align: center; }
  .feature-list { margin: var(--space-lg) 0; display: flex; flex-direction: column; gap: var(--space-md); }
  .feature-list li { display: flex; gap: var(--space-md); }
  .feature-icon { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; flex-shrink: 0; background: rgba(186, 120, 49, 0.15); color: var(--color-accent-dark); border-radius: 50%; font-weight: bold; }
  .feature-list hstrong { font-size: 1.1rem; color: var(--color-primary); }
  .feature-list p { margin: 0; font-size: 0.95rem; color: var(--color-text-secondary); }

  /* Main Offering Preview */
  .offering-grid { display: grid; grid-template-columns: 2fr 1fr; grid-template-rows: repeat(2, 240px); gap: var(--space-md); }
  .offering-card { position: relative; border-radius: var(--radius-md); overflow: hidden; cursor: pointer; }
  .offering-card.large { grid-row: span 2; }
  .offering-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
  .offering-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 60%); display: flex; align-items: flex-end; padding: var(--space-lg); }
  .offering-overlay h3 { color: white; margin: 0; font-size: 1.8rem; transform: translateY(10px); transition: all 0.3s ease; }
  .offering-card:hover .offering-img { transform: scale(1.05); }
  .offering-card:hover .offering-overlay h3 { transform: translateY(0); color: var(--color-accent-light); }

  /* Services Grid */
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); }
  .service-card { display: block; background: var(--color-surface); padding: var(--space-xl); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--color-border); transition: all var(--transition-base); }
  .service-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); border-color: var(--color-accent); }
  .service-icon-wrapper { width: 72px; height: 72px; background: linear-gradient(135deg, rgba(49,115,186,0.1), rgba(49,115,186,0.05)); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; margin-bottom: var(--space-lg); transition: all var(--transition-base); }
  .service-card:hover .service-icon-wrapper { background: var(--color-accent); }
  .service-icon-wrapper svg { width: 36px; height: 36px; fill: none; stroke: var(--color-primary); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; transition: all var(--transition-base); }
  .service-card:hover .service-icon-wrapper svg { stroke: white; }
  .service-card h3 { color: var(--color-primary); margin-bottom: var(--space-sm); }
  .service-card p { color: var(--color-text-secondary); margin-bottom: var(--space-lg); }
  .service-link { font-weight: 600; color: var(--color-primary); text-transform: uppercase; font-size: 0.9rem; letter-spacing: 0.05em; transition: all var(--transition-base); }
  .service-card:hover .service-link { color: var(--color-accent); margin-left: 5px; }



  /* Contact Form */
  .contact-grid { align-items: start; }
  .contact-list { margin-top: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-lg); }
  .contact-list li { display: flex; gap: var(--space-md); align-items: flex-start; }
  .icon-box { width: 48px; height: 48px; background: rgba(49,115,186,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .icon-box svg { width: 24px; height: 24px; stroke: var(--color-primary); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .contact-list strong { display: block; font-size: 1.1rem; color: var(--color-primary); margin-bottom: 4px; }
  .contact-list p { margin: 0; color: var(--color-text-secondary); }
  .form-wrapper { background: var(--color-surface); padding: var(--space-2xl); border-radius: var(--radius-md); box-shadow: var(--shadow-md); border: 1px solid var(--color-border); }

  .mt-xl { margin-top: var(--space-xl); }

  @media (max-width: 960px) {
    .grid-2 { grid-template-columns: 1fr; gap: var(--space-2xl); }
    .about-image-wrapper { max-width: 500px; margin: 0 auto; }
    .offering-grid { grid-template-columns: 1fr; grid-template-rows: auto; }
    .offering-card.large { grid-row: auto; height: 300px; }
    .offering-card { height: 240px; }
  }
  @media (max-width: 600px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); }
    .stat-number, .stat-percent { font-size: 2.5rem; }
    .stat-label { font-size: 0.85rem; }
    .hero-content { align-items: center; text-align: center; }
    .hero-btn-group { flex-direction: column; width: 100%; gap: var(--space-md); }
    .hero-subtitle { font-size: 1.1rem; }
    .form-wrapper { padding: var(--space-lg); }
  }
</style>

<script>
  // Counter Animation
  function animateCounters() {
    document.querySelectorAll('.stat-number').forEach(counter => {
      const target = parseInt(counter.getAttribute('data-target') || '0', 10);
      const duration = 2000;
      const stepTime = 20;
      const steps = duration / stepTime;
      const increment = target / steps;
      let current = 0;
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          counter.textContent = target.toString();
          clearInterval(timer);
        } else {
          counter.textContent = Math.floor(current).toString();
        }
      }, stepTime);
    });
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounters();
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });
  
  const statsSection = document.getElementById('stats');
  if (statsSection) observer.observe(statsSection);

  // Form Submission feedback
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('contact-submit');
    if(btn) {
      const originalText = btn.textContent;
      btn.textContent = '¡Mensaje enviado! ✓';
      btn.style.background = 'var(--color-success)';
      btn.style.borderColor = 'var(--color-success)';
      setTimeout(() => {
        btn.textContent = originalText;
        btn.style.background = '';
        btn.style.borderColor = '';
        form.reset();
      }, 3000);
    }
  });
</script>
