---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/galeria', label: 'Galería' },
];
const currentPath = Astro.url.pathname;
---

<header id="main-header" class="header">
  <div class="top-bar">
    <div class="container top-bar-container">
      <div class="top-bar-contact">
        <a href="tel:+51920324996" class="top-bar-link">
          <svg viewBox="0 0 24 24" class="top-icon"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
          +51 920 324 996
        </a>
        <a href="/#contacto" class="top-bar-link hide-mobile">
          <svg viewBox="0 0 24 24" class="top-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          Calle Huánuco G19 Mz F2 Lt 4 – Cerro Colorado, Arequipa
        </a>
      </div>
      <div class="top-bar-social">
        <a href="#" class="top-bar-social-link" aria-label="Facebook">
          <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3.81l.19-4h-4V7a1 1 0 011-1h3z"></path></svg>
        </a>
        <a href="#" class="top-bar-social-link" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
        <a href="#" class="top-bar-social-link" aria-label="Instagram">
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="container header-container">
    <a href="/" class="brand-link" aria-label="H&H Inicio">
      <img src="/logo_2.png" alt="H&H Diseño Fabricacion y Montaje" class="brand-logo" />
      <span class="brand-text">H&H Diseño Fabricación<br/>y Montaje</span>
    </a>

    <nav class="desktop-nav">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class:list={['nav-link', { active: currentPath === link.href || currentPath === link.href + '/' }]}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <a href="/#contacto" class="btn btn-primary btn-sm nav-cta">Cotizar</a>
    </nav>

    <button class="mobile-toggle" aria-label="Abrir menú" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>

  <div class="mobile-overlay">
    <nav class="mobile-nav">
      <ul class="mobile-nav-list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class:list={['mobile-nav-link', { active: currentPath === link.href || currentPath === link.href + '/' }]}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <a href="/#contacto" class="btn btn-primary nav-cta mt-xl">Solicitar Presupuesto</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: transparent;
    z-index: 100;
    transition: all var(--transition-base);
    border-bottom: 1px solid transparent;
  }
  .header.scrolled {
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-sm);
    border-bottom-color: var(--color-border);
  }
  
  /* Top Bar Styles */
  .top-bar {
    background: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: all var(--transition-base);
    min-height: 44px;
    overflow: hidden;
  }
  .header.scrolled .top-bar {
    min-height: 0;
    height: 0;
    opacity: 0;
    border-color: transparent;
    padding: 0;
  }
  .top-bar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
    min-height: 44px;
    font-size: 0.75rem;
    color: #eeeeee;
    font-family: var(--font-body);
    letter-spacing: 0.03em;
  }
  .top-bar-contact {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }
  .top-bar-link {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    transition: color var(--transition-fast);
    padding: 8px 0;
  }
  .top-bar-link:hover {
    color: var(--color-accent);
  }
  .top-icon {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .top-bar-social {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }
  .top-bar-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: #eeeeee;
    transition: all var(--transition-base);
  }
  .top-bar-social-link svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .top-bar-social-link:hover {
    background: var(--color-accent);
    color: white;
    transform: translateY(-2px);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
  }
  .brand-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .brand-logo {
    max-height: 65px;
    width: auto;
    object-fit: contain;
  }
  .brand-text {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, #7a4714 0%, #BA7831 25%, #f2c97d 50%, #BA7831 75%, #965C21 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    -webkit-text-stroke: 0.5px rgba(0, 0, 0, 0.6);
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.3));
  }
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }
  .nav-list {
    display: flex;
    gap: var(--space-lg);
  }
  .nav-link {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    position: relative;
    padding: var(--space-xs) 0;
    transition: color var(--transition-base);
  }
  .header.scrolled .nav-link {
    color: var(--color-text);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--color-accent);
    transition: all var(--transition-base);
  }
  .nav-link:hover::after, .nav-link.active::after {
    width: 100%;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--color-accent);
  }
  .header.scrolled .nav-link:hover, .header.scrolled .nav-link.active {
    color: var(--color-primary);
  }
  
  .mobile-toggle {
    display: block; /* Default for mobile */
    background: none;
    border: none;
    cursor: pointer;
    width: 44px; /* Increased touch area */
    height: 44px; /* Increased touch area */
    position: relative;
    z-index: 101;
  }
  .hamburger, .hamburger::before, .hamburger::after {
    display: block;
    width: 24px;
    height: 2px;
    background: #ffffff;
    transition: all var(--transition-base);
  }
  .header.scrolled .hamburger,
  .header.scrolled .hamburger::before,
  .header.scrolled .hamburger::after {
    background: var(--color-primary);
  }
  .hamburger {
    position: relative;
    margin: 0 auto;
  }
  .hamburger::before, .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
  }
  .hamburger::before { top: -8px; }
  .hamburger::after { bottom: -8px; }

  .mobile-toggle.open .hamburger { background: transparent !important; }
  .mobile-toggle.open .hamburger::before { top: 0; transform: rotate(45deg); background: var(--color-text) !important; }
  .mobile-toggle.open .hamburger::after { bottom: 0; transform: rotate(-45deg); background: var(--color-text) !important; }

  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: all var(--transition-base);
    z-index: 99;
  }
  .mobile-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .mobile-nav {
    text-align: center;
    width: 100%;
    padding: var(--space-xl);
  }
  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }
  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
  }
  .mobile-nav-link.active {
    color: var(--color-accent);
  }
  .mt-xl { margin-top: var(--space-xl); }

  /* Mobile Defaults */
  .desktop-nav { display: none; }
  .top-bar-container { justify-content: center; }
  .hide-mobile { display: none; }
  .brand-text { display: none; }
  .brand-logo { max-height: 55px; }

  /* Tablet */
  @media (min-width: 481px) {
    .brand-text { display: block; }
    .brand-logo { max-height: 65px; }
    .top-bar-container { justify-content: space-between; }
    .hide-mobile { display: flex; }
  }

  /* Desktop */
  @media (min-width: 1025px) {
    .desktop-nav { display: flex; }
    .mobile-toggle { display: none; }
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const toggle = document.querySelector('.mobile-toggle');
  const overlay = document.querySelector('.mobile-overlay');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.classList.toggle('open');
    overlay?.classList.toggle('open');
    if (isOpen) {
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    } else {
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
  });

  document.querySelectorAll('.mobile-nav-link, .mobile-overlay .nav-cta').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.classList.remove('open');
      overlay?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
