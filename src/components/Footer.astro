---
const currentYear = new Date().getFullYear();
const navLinks1 = [
  { href: '/', label: 'Inicio' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/galeria', label: 'Galería' },
];
const navLinks2 = [
  { href: '/#contacto', label: 'Contacto' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="brand-link" aria-label="H&H Inicio">
          <img src="/logo_2.png" alt="H&H Diseño Fabricacion y Montaje" class="brand-logo" />
          <span class="brand-text">H&H Diseño Fabricación<br/>y Montaje</span>
        </a>
        <p class="brand-desc">
          Especialistas en Metalmecánica, Montaje Industrial y Fabricación Estructural con los más altos estándares de calidad.
        </p>
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3.81l.19-4h-4V7a1 1 0 011-1h3z"></path></svg>
          </a>
          <a href="#" class="social-link" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <a href="#" class="social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
      </div>
      
      <div class="footer-nav">
        <h3 class="footer-title">Enlaces</h3>
        <div class="nav-columns">
          <ul class="footer-list">
            {navLinks1.map(link => (
              <li><a href={link.href} class="footer-link">{link.label}</a></li>
            ))}
          </ul>
          <ul class="footer-list">
            {navLinks2.map(link => (
              <li><a href={link.href} class="footer-link">{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <div class="footer-contact">
        <h3 class="footer-title">Contacto</h3>
        <ul class="contact-list">
          <li>
            <svg viewBox="0 0 24 24" class="contact-icon"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
            <span>+51 921 941 470</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" class="contact-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <span>servicios@hhdfm.com</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" class="contact-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <span>hyh.dfm@gmail.com</span>
          </li>

          <li>
            <svg viewBox="0 0 24 24" class="contact-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span>Calle Huánuco G19 Mz F2 Lt 4 – Cerro Colorado, Arequipa</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} H&H Diseño Fabricacion y Montaje. Todos los derechos reservados.</p>
      <div class="legal-links">
        <a href="#">Términos y Condiciones</a>
        <a href="#">Política de Privacidad</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--grad-primary);
    padding: var(--space-4xl) 0 0 0;
    color: rgba(255,255,255,0.7);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr; /* Default mobile 1 column */
    gap: var(--space-3xl);
    margin-bottom: var(--space-4xl);
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .brand-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }
  .brand-logo {
    max-height: 80px;
    width: auto;
    object-fit: contain;
  }
  .brand-text {
    font-family: 'Orbitron', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, #7a4714 0%, #BA7831 25%, #f2c97d 50%, #BA7831 75%, #965C21 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    -webkit-text-stroke: 0.5px rgba(0, 0, 0, 0.6);
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.3));
  }
  .brand-desc {
    max-width: 320px;
    margin: 0;
  }
  .social-links {
    display: flex;
    gap: var(--space-md);
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: white;
    transition: all var(--transition-base);
  }
  .social-link:hover {
    background: var(--color-accent-light);
    color: white;
    transform: translateY(-3px);
  }
  .social-link svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .footer-title {
    color: white;
    font-size: 1.6rem;
    margin-bottom: var(--space-lg);
  }
  .nav-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }
  .footer-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .footer-link {
    transition: all var(--transition-fast);
  }
  .footer-link:hover {
    color: var(--color-accent-light);
  }
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }
  .contact-icon {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    padding: var(--space-xl) 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 0.9rem;
  }
  .legal-links {
    display: flex;
    gap: var(--space-md);
  }
  .legal-links a {
    transition: all var(--transition-fast);
  }
  .legal-links a:hover {
    color: var(--color-accent-light);
  }
  
  /* Tablet */
  @media (min-width: 481px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  
  /* Desktop */
  @media (min-width: 1025px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }
</style>
