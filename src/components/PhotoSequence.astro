---
interface Props {
  images: { src: string; alt: string }[];
  interval?: number;
  class?: string;
}

const { images, interval = 3000, class: className = '' } = Astro.props;
const seqId = Math.random().toString(36).substring(2, 9);
---

<div class={`photo-sequence ${className}`} id={`ps-${seqId}`} data-interval={interval}>
  {images.map((img, index) => (
    <div class={`ps-slide ${index === 0 ? 'active' : ''}`}>
      <img src={img.src} alt={img.alt} loading="lazy" />
    </div>
  ))}
</div>

<style>
  .photo-sequence {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--color-surface);
  }
  .ps-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ps-slide.active {
    opacity: 1;
    z-index: 1;
  }
  .ps-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  function initPhotoSequences() {
    const sequences = document.querySelectorAll('.photo-sequence');
    sequences.forEach(seq => {
      if (seq.hasAttribute('data-initialized')) return;
      seq.setAttribute('data-initialized', 'true');
      
      const slides = seq.querySelectorAll('.ps-slide');
      if (slides.length <= 1) return;
      
      let currentIdx = 0;
      const interval = parseInt(seq.getAttribute('data-interval') || '3000', 10);
      
      setInterval(() => {
        slides[currentIdx].classList.remove('active');
        currentIdx = (currentIdx + 1) % slides.length;
        slides[currentIdx].classList.add('active');
      }, interval);
    });
  }

  // Initial load
  initPhotoSequences();
  // Support for Astro View Transitions if enabled
  document.addEventListener('astro:page-load', initPhotoSequences);
</script>
