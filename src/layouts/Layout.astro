---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = 'H&H Diseño Fabricacion y Montaje — Especialistas en Metalmecánica, Fabricación Estructural y Montaje Industrial en Arequipa y todo el Perú.',
  keywords = 'metalmecánica, estructuras metálicas, montaje industrial, ingeniería, piezas mecánicas, mantenimiento industrial, Arequipa, Perú, soldadura, arenado, pintura industrial',
  ogImage = '/logo.png',
  canonical = new URL(Astro.url.pathname, Astro.site || 'https://hhdfm.com').toString(),
} = Astro.props;

// Schema.org Structured Data
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "H&H Diseño Fabricación y Montaje",
  "image": new URL(ogImage, Astro.site || 'https://hhdfm.com').toString(),
  "description": description,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Huánuco G19 Mz F2 Lt 4 – Semi Rural Pachacútec",
    "addressLocality": "Cerro Colorado, Arequipa",
    "addressRegion": "ARE",
    "postalCode": "04014",
    "addressCountry": "PE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -16.3575,
    "longitude": -71.5542
  },
  "url": Astro.site || 'https://hhdfm.com',
  "telephone": "+51921941470",
  "email": "servicios@hhdfm.com"
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="H&H Diseño Fabricacion y Montaje" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- GEO / Local SEO para Búsquedas e IA -->
    <meta name="geo.region" content="PE-ARE" />
    <meta name="geo.placename" content="Arequipa" />
    <meta name="geo.position" content="-16.3575;-71.5542" />
    <meta name="ICBM" content="-16.3575, -71.5542" />

    <!-- Open Graph / Web -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site || 'https://hhdfm.com').toString()} />
    <meta property="og:site_name" content="H&H Diseño Fabricación y Montaje" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site || 'https://hhdfm.com').toString()} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data (Schema.org) para Google / IA -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
  </body>
</html>
